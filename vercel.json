{
    "services": {
        "frontend": {
            "root": ".",
            "framework": "nextjs"
        },
        "note-pipeline": {
            "root": "services/note-pipeline",
            "entrypoint": "main.py"
        }
    },
    "rewrites": [
        {
            "source": "/api/note-pipeline(/.*)?",
            "destination": {
                "type": "service",
                "service": "note-pipeline"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
