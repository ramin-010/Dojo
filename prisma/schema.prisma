generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ====================================================================
// LEVEL 1: WORKSPACE & USER
// ====================================================================

enum RoutineMode {
  MASTER
  DAILY
}


model User {
  id         String       @id @default(uuid()) // Hardcoded initially
  email      String?      @unique
  name       String?
  workspaces Workspace[]
  streaks    SubjectStreak[]
  history    DailyHistory[]
  settings   UserSettings?
}

model Workspace {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  name      String
  subjects       Subject[]
  noteCategories NoteCategory[]
  captures       Capture[]
  timeBlocks     TimeBlock[]
  routineMode    RoutineMode @default(MASTER)
}

// ====================================================================
// LEVEL 2: SUBJECT DASHBOARD
// ====================================================================

model Subject {
  id           String         @id @default(uuid())
  workspaceId  String
  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  name         String
  description  String?        // "About this subject" text
  icon         String?
  color        String?
  
  lastActiveAt DateTime       @default(now()) // Updated when a topic is touched
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  topics       Topic[]
  captures     Capture[]
  tags         Tag[]
  streaks      SubjectStreak[]
  history      DailyHistory[]
}

// ====================================================================
// LEVEL 2.5: CATEGORIES

model NoteCategory {
  id          String      @id @default(uuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  name        String      // e.g., "Idea", "To-Do"
  color       String?     // Tailwind class or hex
  icon        String?     // Lucide icon name
  
  captures    Capture[]

  @@unique([workspaceId, name])
}

// ====================================================================
// NEW: CAPTURE & BEHAVIOR LAYER
// ====================================================================

enum CaptureType {
  NOTE
  TASK
  LINK
}

model Capture {
  id            String      @id @default(uuid())
  workspaceId   String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  type          CaptureType @default(NOTE)

  // ── Universal fields ──
  title         String?
  isPinned      Boolean     @default(false)

  // ── Hierarchy (optional) ──
  subjectId     String?
  subject       Subject?    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topicId       String?
  topic         Topic?      @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // ── Category (unified) ──
  categoryId    String?
  category      NoteCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // ── Type-specific fields ──
  content       String?     // NOTE: the body text
  url           String?     // LINK: the URL or text reference
  cloudPublicId String?     // LINK: If present, this is a self-hosted cloud asset
  fileType      String?     // LINK: Original mime-type for uploaded files
  isDone        Boolean     @default(false)  // TASK: completion state
  dueDate       DateTime?   // TASK: when it's due (also used for Note/Link inline dates if not using Reminder)

  // ── Behaviors ──
  reminder      Reminder?   // 0 or 1
  revisions     Revision[]  // 0 to many
  attachments   Attachment[] // 0 to many

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([workspaceId, type])
  @@index([subjectId])
  @@index([topicId])
  @@index([dueDate])
}

// A one-time reminder attached to any Capture
model Reminder {
  id          String    @id @default(uuid())

  captureId   String    @unique        // 1:1 with Capture
  capture     Capture   @relation(fields: [captureId], references: [id], onDelete: Cascade)

  remindAt    DateTime                 // When to fire the reminder
  isDismissed Boolean   @default(false)

  createdAt   DateTime  @default(now())

  @@index([remindAt])
}

// Attachments for a Capture
model Attachment {
  id            String    @id @default(uuid())
  captureId     String
  capture       Capture   @relation(fields: [captureId], references: [id], onDelete: Cascade)
  url           String
  cloudPublicId String
  fileType      String?
  fileName      String?
  createdAt     DateTime  @default(now())

  @@index([captureId])
}

// ====================================================================
// LEVEL 3: TOPICS, TAGS & SPATIAL CANVAS
// ====================================================================

model Tag {
  id        String   @id @default(uuid())
  subjectId String
  name      String   
  
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topics    Topic[]

  @@unique([subjectId, name])
}

model Topic {
  id          String   @id @default(uuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  title       String
  tags        Tag[] 
  sortOrder   Float?   // Allows drag-and-drop or Previous/Next navigation
  isArchived  Boolean  @default(false)
  
  // The Hybrid Spatial Data! All blocks/connections live here.
  canvasData  Json?    @default("{}") 
  
  revisions   Revision[]
  mentionsOut TopicMention[] @relation("SourceTopic")
  mentionsIn  TopicMention[] @relation("TargetTopic")
  
  captures    Capture[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Extracted from Canvas text blocks on save for easy timeline querying
model TopicMention {
  id            String   @id @default(uuid())
  sourceTopicId String
  sourceTopic   Topic    @relation("SourceTopic", fields: [sourceTopicId], references: [id], onDelete: Cascade)
  targetTopicId String
  targetTopic   Topic    @relation("TargetTopic", fields: [targetTopicId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([sourceTopicId, targetTopicId])
}

// ====================================================================
// LEVEL 4: SPACED REPETITION & GAMIFICATION
// ====================================================================

// A Topic is "Not Started" if count(Revision) == 0.
// Once started, the cycle is locked. Schedule changes cannot happen mid-flight.
model Revision {
  id           String    @id @default(uuid())
  
  topicId      String?
  topic        Topic?    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  
  captureId    String?
  capture      Capture?  @relation(fields: [captureId], references: [id], onDelete: Cascade)
  
  cycleNumber  Int       // To sort the progress bar (1, 2, 3, 4)
  intervalDays Int       // Used to dynamically recalculate next cascading date if user is late
  
  scheduledFor DateTime  // Midnight of the due day
  completedAt  DateTime? 
  status       String    @default("pending") // "pending", "done", "missed"
  createdAt    DateTime  @default(now())

  @@index([scheduledFor, status])
  @@index([captureId])
  @@index([topicId])
}

// Powers the "Recent Activity" list on the Subject profile
model ActivityLog {
  id          String   @id @default(uuid())
  userId      String   
  subjectId   String?  
  topicId     String?
  
  action      String   // "CREATED_TOPIC", "EDITED_TOPIC", "COMPLETED_REVISION"
  details     String?  // e.g., "Generics in TS" (saves a JOIN when rendering the list)
  
  createdAt   DateTime @default(now())
}

// The lazy-evaluated Streak system per Subject
model SubjectStreak {
  userId          String
  subjectId       String
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastCalculated  DateTime // Prevents continuous recalculation

  @@id([userId, subjectId])
}

// Powers the 7-day flame graph per Subject
model DailyHistory {
  id              String   @id @default(uuid())
  userId          String
  subjectId       String
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  date            DateTime // Midnight of the evaluated day
  
  revisionsDue    Int      
  revisionsDone   Int      
  streakMaintained Boolean // True if Due == Done
}

// ====================================================================
// LEVEL 5: TIMEBLOCKS
// ====================================================================

model TimeBlock {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  title           String
  startTime       String    // e.g. "09:00"
  endTime         String    // e.g. "11:00"
  color           String    // e.g. "#10b981"
  dayOfWeek       Int?      // 0-6, null if it's a specific date
  date            DateTime? // If it's a one-off block on a specific date

  sessionLogs     ScheduleSessionLog[]

  createdAt       DateTime  @default(now())
}

// ====================================================================
// LEVEL 6: SCHEDULE TRACKING & TRIAGE
// ====================================================================

enum BlockOutcome {
  COMPLETED        // User marked the block as done
  COMPLETED_EARLY  // User ended the block before its scheduled end
  SKIPPED          // User actively skipped (with remark)
  PRE_SKIPPED      // User proactively skipped a future block today
  INTERRUPTED      // User was mid-block and had to abandon
  OVERWRITTEN      // This block's slot was taken by another block
  EXTENDED         // A previous block extended into this one (Flow State)
  UNRESOLVED       // System-generated: block expired with no interaction
}

model ScheduleSessionLog {
  id              String       @id @default(uuid())
  userId          String
  workspaceId     String

  // What block was this?
  timeBlockId     String
  timeBlock       TimeBlock    @relation(fields: [timeBlockId], references: [id], onDelete: Cascade)
  blockTitle      String       // Denormalized snapshot
  blockColor      String       // Denormalized snapshot

  // When was it scheduled?
  date            DateTime     // Midnight of the scheduled day
  scheduledStart  String       // "09:00"
  scheduledEnd    String       // "11:00"

  // What actually happened?
  outcome         BlockOutcome
  remark          String?      // User-provided reason
  remarkCategory  String?      // "WORK_EMERGENCY", "PERSONAL", "HEALTH", "FLOW_STATE", "OTHER"

  // Timing metadata
  actualStartAt   DateTime?
  actualEndAt     DateTime?
  minutesLogged   Int          @default(0)

  // Overwrite context
  replacedByTitle String?
  replacedById    String?

  // Triage metadata
  resolvedAt      DateTime?
  isTriaged       Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId, date])
  @@index([workspaceId, date])
  @@index([outcome])
}

model UserSettings {
  userId          String    @id
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  bufferDay       Int       @default(6)  // 0=Mon...6=Sun. Default Sunday.

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
